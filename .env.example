# LangSmith（LangGraph Studio 连接需要，在 https://smith.langchain.com 获取）
LANGSMITH_API_KEY=

DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
LLM_TIMEOUT_SECONDS=300
LLM_RETRY_TIMES=1

AGENT_CONFIG_PATH=config/agents.yaml
# MySQL 8.0+ business database. Example: mysql://user:password@127.0.0.1:3306/patent_tutor
PATENT_TUTOR_MYSQL_URL=
PATENT_TUTOR_MYSQL_POOL_SIZE=5
PATENT_TUTOR_MYSQL_CONNECT_TIMEOUT=5
PATENT_TUTOR_MYSQL_AUTO_MIGRATE=true
ARTIFACT_ROOT=artifacts
WORKFLOW_LOG_ROOT=artifacts
STUDIO_THIRD_PARTY_LOG_LEVEL=ERROR
PATENT_TUTOR_CORS_ORIGINS=
PATENT_TUTOR_CORS_ALLOW_CREDENTIALS=false
PATENT_TUTOR_SESSION_TTL_SECONDS=3600
PATENT_TUTOR_ENV=development

# RAG defaults to real Milvus Lite + BGE-M3 retrieval.
# Set RAG_RETRIEVAL_MODE=mock only when you intentionally need fixed demo chunks.
RAG_RETRIEVAL_MODE=real

# Optional complete local BGE-M3 model directory. When set, RAG does not download from the network.
RAG_EMBEDDING_MODEL_PATH=
